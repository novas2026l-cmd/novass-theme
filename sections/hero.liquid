<section class="hero" id="hero">
  <div class="hero-content">
    <div class="hero-eyebrow reveal">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/></svg>
      {{ section.settings.eyebrow | default: 'Always Free & Fresh' }}
    </div>
    <h1 class="hero-title reveal reveal-delay-1">{{ section.settings.title | default: 'Your body will <em>thank you</em>' }}</h1>
    <p class="hero-subtitle reveal reveal-delay-2">{{ section.settings.subtitle | default: 'Feel the air like a fresh, dewy leaf brushing against your skin. Cool, soft, and natural.' }}</p>
    <div class="hero-actions reveal reveal-delay-3">
      <a href="{{ section.settings.cta_url | default: routes.collections_url }}" class="btn btn--primary btn--lg">{{ section.settings.cta_text | default: 'Shop Now' }}</a>
      {%- if section.settings.secondary_cta_text != blank -%}
        <a href="{{ section.settings.secondary_cta_url }}" class="btn btn--outline btn--lg">{{ section.settings.secondary_cta_text }}</a>
      {%- endif -%}
    </div>
    <div class="hero-trust reveal reveal-delay-4">
      <div class="hero-trust-stars">
        {%- for i in (1..5) -%}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/></svg>{%- endfor -%}
      </div>
      <p class="hero-trust-text"><strong>+500 customers</strong> already love it</p>
    </div>
  </div>
  <div class="hero-image">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="{{ section.settings.hero_image.alt | default: shop.name }}" width="1200" height="900" loading="eager" fetchpriority="high">
    {%- else -%}
      <img src="{{ 'product-1.png' | asset_url }}" alt="{{ shop.name }}" width="1200" height="900" loading="eager" fetchpriority="high">
    {%- endif -%}
    <div class="hero-badge"><span class="hero-badge-label">Limited stock</span><span class="hero-badge-value">Order now →</span></div>
  </div>
</section>
{% schema %}{"name":"Hero","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow text","default":"Always Free & Fresh"},{"type":"textarea","id":"title","label":"Heading","default":"Your body will <em>thank you<\/em>"},{"type":"textarea","id":"subtitle","label":"Subtitle","default":"Feel the air like a fresh, dewy leaf brushing against your skin. Cool, soft, and natural."},{"type":"image_picker","id":"hero_image","label":"Hero image"},{"type":"text","id":"cta_text","label":"Button text","default":"Shop Now"},{"type":"url","id":"cta_url","label":"Button URL"},{"type":"text","id":"secondary_cta_text","label":"Secondary button text"},{"type":"url","id":"secondary_cta_url","label":"Secondary button URL"}],"presets":[{"name":"Hero"}]}{% endschema %}
