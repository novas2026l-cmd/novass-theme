<section class="testimonials section">
  <div class="container">
    <div class="testimonials-header">
      <h2 class="reveal">{{ section.settings.title | default: 'What customers say' }}</h2>
      <p class="reveal reveal-delay-1">{{ section.settings.subtitle | default: 'Real people, real relief.' }}</p>
    </div>
    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card reveal reveal-delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="testimonial-stars">{%- for i in (1..5) -%}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/></svg>{%- endfor -%}</div>
          <p class="testimonial-text">"{{ block.settings.text }}"</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">{{ block.settings.name | slice: 0 }}</div>
            <div><p class="testimonial-name">{{ block.settings.name }}</p><p class="testimonial-verified">✓ Verified purchase</p></div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}{"name":"Testimonials","settings":[{"type":"text","id":"title","label":"Title","default":"What customers say"},{"type":"text","id":"subtitle","label":"Subtitle","default":"Real people, real relief."}],"blocks":[{"type":"review","name":"Review","settings":[{"type":"text","id":"name","label":"Customer name"},{"type":"textarea","id":"text","label":"Review text"}]}],"presets":[{"name":"Testimonials","blocks":[{"type":"review","settings":{"name":"Amy E.","text":"I take it everywhere — the gym, the office, even the car. It's so quiet I forget it's on. Absolute game changer for summer."}},{"type":"review","settings":{"name":"Michelle","text":"It actually clips onto my shirt collar and the airflow is incredible. Light as a feather too."}},{"type":"review","settings":{"name":"Cindy","text":"Battery lasts the whole workday. I charged it once on Monday and used it all week."}},{"type":"review","settings":{"name":"Amanda","text":"Bought it for outdoor events during summer and it saved me. The 3-speed control is perfect."}},{"type":"review","settings":{"name":"John Peterson","text":"Got this for my wife who works outdoors. She loves it so much I ordered one for myself."}},{"type":"review","settings":{"name":"JY","text":"Tiny but mighty. The airflow rivals fans 10x its size. Shipped fast and packaged beautifully."}}]}]}{% endschema %}
