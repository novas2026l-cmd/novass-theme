<div class="collection-page">
  <div class="collection-header reveal"><h1>{{ collection.title }}</h1>{%- if collection.description != blank -%}<p style="color:var(--color-text-muted);margin-top:12px;max-width:600px;">{{ collection.description }}</p>{%- endif -%}</div>
  <div class="collection-grid">
    {%- for product in collection.products -%}
      <a href="{{ product.url }}" class="product-card reveal reveal-delay-{{ forloop.index | modulo: 4 | plus: 1 }}">
        <div class="product-card-image">
          {%- if product.featured_image != blank -%}<img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title }}" width="600" height="600" loading="lazy">
          {%- else -%}<img src="{{ 'product-1.png' | asset_url }}" alt="{{ product.title }}" width="600" height="600" loading="lazy">{%- endif -%}
        </div>
        <div class="product-card-info"><h3 class="product-card-title">{{ product.title }}</h3><p class="product-card-price">{{ product.price | money }}</p></div>
      </a>
    {%- else -%}<p style="color:var(--color-text-muted);">No products found.</p>
    {%- endfor -%}
  </div>
</div>
