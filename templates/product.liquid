{%- assign current_variant = product.selected_or_first_available_variant -%}
<div class="product-page">
  <div class="product-page-inner">
    <div class="product-page-images reveal-left">
      <div class="main-image"><img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | default: product.title }}" width="800" height="800" loading="eager"></div>
      {%- if product.images.size > 1 -%}
        <div class="product-page-thumbs">
          {%- for image in product.images -%}<img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | default: product.title }}" loading="lazy" class="{% if forloop.first %}active{% endif %}">{%- endfor -%}
        </div>
      {%- endif -%}
    </div>
    <div class="product-page-info reveal-right">
      <h1 style="font-size:clamp(1.6rem,3vw,2.4rem);">{{ product.title }}</h1>
      <div class="product-stars">
        <span class="stars">{%- for i in (1..5) -%}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" style="width:18px;height:18px;fill:var(--color-star);"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/></svg>{%- endfor -%}</span>
        <span class="count" style="font-size:.9rem;color:var(--color-text-muted);">5.0 (124 reviews)</span>
      </div>
      <div style="font-family:var(--font-heading);font-size:2rem;font-weight:700;color:var(--color-primary);">
        {%- if current_variant.compare_at_price > current_variant.price -%}<span style="text-decoration:line-through;color:var(--color-text-muted);font-size:1.4rem;margin-right:12px;">{{ current_variant.compare_at_price | money }}</span>{%- endif -%}
        {{ current_variant.price | money }}
      </div>
      <div style="font-size:.95rem;color:var(--color-text-muted);line-height:1.75;">{{ product.description }}</div>
      {%- form 'product', product, data-add-to-cart: '' -%}
        {%- if product.variants.size > 1 -%}
          <select name="id" style="padding:10px 14px;border:1px solid var(--color-border);border-radius:var(--radius-sm);font-family:var(--font-body);width:100%;background:var(--color-white);">
            {%- for variant in product.variants -%}<option value="{{ variant.id }}"{% if variant == current_variant %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>{{ variant.title }} — {{ variant.price | money }}</option>{%- endfor -%}
          </select>
        {%- else -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {%- endif -%}
        <div class="product-quantity" style="margin-bottom:16px;"><button type="button" data-action="minus">−</button><input type="number" name="quantity" value="1" min="1"><button type="button" data-action="plus">+</button></div>
        <div class="product-form">
          {%- if current_variant.available -%}
            <button type="submit" class="btn btn--primary btn--lg btn--full" data-add-to-cart-btn>Add to Cart — {{ current_variant.price | money }}</button>
          {%- else -%}
            <button class="btn btn--outline btn--lg btn--full" disabled style="opacity:.5;cursor:not-allowed;">Sold Out</button>
          {%- endif -%}
        </div>
      {%- endform -%}
    </div>
  </div>
</div>
